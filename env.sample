# Copy this file to .env and fill in your own values.
# These are substituted into SKILL.md files at package time by package.sh.

# Username for an admin-capable MySQL/MariaDB account. This is usually (but not
# necessarily) the root account. This account is used to create databases and users.
MYSQL_ADMIN_USER="root"

# Password for the admin-capable MySQL/MariaDB account above.
MYSQL_ADMIN_PASSWORD="myrootpassword"

# Path to the local Akeeba Kickstart source repository (ks9). Used by the restore
# skill to build Kickstart locally when no pre-built release is available.
AKEEBA_KS_DIR="~/Projects/akeeba/ks9"

# The parent directory where local Joomla sites are created.
# When a skill installs or works with a site, this is the default location.
JOOMLA_SITES_DIR="~/Sites"

# The local domain suffix used to construct site URLs.
# For example, a site named "mysite" will be accessible at http://mysite.example.test
JOOMLA_SITE_DOMAIN="example.test"

# Full display name for the Joomla Super Administrator account created during installation.
JOOMLA_ADMIN_NAME="Jane Doe"

# Username for the Joomla Super Administrator account.
JOOMLA_ADMIN_USERNAME="janedoe"

# Password for the Joomla Super Administrator account.
JOOMLA_ADMIN_PASSWORD="Ch@ngeMe123"

# Email address for the Joomla Super Administrator account.
JOOMLA_ADMIN_EMAIL="jane@example.com"
